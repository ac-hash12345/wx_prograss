.order-item { margin-bottom: 15px; background: #fff; padding: 10px; border-bottom: 5px solid #eee; }
.header { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 10px; border-bottom: 1px solid #f8f8f8; padding-bottom: 5px; }
.status { color: red; }
.goods-item { display: flex; margin-bottom: 10px; }
.goods-item image { width: 60px; height: 60px; margin-right: 10px; }
.info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.footer { text-align: right; font-weight: bold; border-top: 1px solid #f8f8f8; padding-top: 5px; }
.empty { text-align: center; padding: 50px; color: #999; }
