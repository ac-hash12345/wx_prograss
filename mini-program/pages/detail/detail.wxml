<view class="container-detail">
  <image src="{{goods.cover}}" class="goods-img"></image>
  <view class="info">
    <text class="title">{{goods.name}}</text>
    <text class="price">￥{{goods.price}}</text>
    <text class="stock">库存: {{goods.stock}}</text>
  </view>
  <view class="detail">
    <text>商品详情：</text>
    <text>{{goods.detail}}</text>
  </view>
  <view class="bottom-bar">
    <button bindtap="addCart">加入购物车</button>
    <button type="warn" bindtap="buyNow">立即购买</button>
  </view>
</view>
